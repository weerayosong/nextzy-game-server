generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nickname    String        @unique
  totalPoints Int           @default(0)
  createdAt   DateTime      @default(now())
  
  // Relations
  spinHistory SpinHistory[]
  rewards     RewardClaim[]

  @@index([nickname])
}

model SpinHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @db.Uuid
  pointsReceived Int
  createdAt      DateTime @default(now())

  // Relations
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // สร้าง Index ที่ userId เพื่อรองรับการค้นหาประวัติ 1 ล้านแถวอย่างรวดเร็ว
  @@index([userId])
}

model RewardClaim {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid
  checkpoint Int      // ค่าที่เก็บ: 500, 1000, 10000
  claimedAt  DateTime @default(now())

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ป้องกันผู้เล่นคนเดิมกดรับรางวัลใน Checkpoint เดิมซ้ำ (Database-Level Protection)
  @@unique([userId, checkpoint])
}